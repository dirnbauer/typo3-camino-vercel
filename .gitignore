# macOS / Windows / filesystem noise
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Local secrets and Vercel project state
.env
.env.*
!.env.example
.vercel/

# Editor and IDE state
.idea/
.vscode/
nbproject/

# Dependencies and build artifacts
/vendor/
/node_modules/
/.phpunit.cache/
/.phpunit.result.cache

# TYPO3 runtime state
/var/

# Public web root: keep only application entrypoints and curated demo assets.
/public/*
!/public/.htaccess
!/public/index.php
!/public/favicon.ico
!/public/template-preview.png
!/public/api/
!/public/api/**

# TYPO3 public runtime directories.
!/public/typo3temp/
/public/typo3temp/*
!/public/typo3temp/index.html

!/public/fileadmin/
/public/fileadmin/*
!/public/fileadmin/.htaccess

# Curated Camino demo files. New editor uploads should go to durable object storage.
!/public/fileadmin/camino/
!/public/fileadmin/camino/**

# Keep the seeded processed demo derivatives, but ignore new runtime derivatives.
!/public/fileadmin/_processed_/
/public/fileadmin/_processed_/**
