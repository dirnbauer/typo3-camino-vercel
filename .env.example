TYPO3_CONTEXT=Production/Vercel
# Use 1 only for the first deploy against a fresh durable database.
TYPO3_AUTO_SETUP=0
TYPO3_BOOTSTRAP_EMPTY_DATABASE=0
TYPO3_SETUP_DISTRIBUTION=theme_camino
TYPO3_SETUP_ADMIN_USERNAME=admin
# The container resolves this admin's real database UID and grants the TYPO3
# System modules automatically. Override only with explicit backend user UIDs:
# TYPO3_SYSTEM_MAINTAINERS=1,7
TYPO3_SETUP_ADMIN_PASSWORD=change-me-with-a-long-random-password-1A!
TYPO3_SETUP_ADMIN_EMAIL=admin@example.com
TYPO3_PROJECT_NAME=TYPO3 Camino
# Required on Vercel: instances are ephemeral, so the container refuses to boot
# without a stable key (a per-instance random key would break cHash and caches).
TYPO3_ENCRYPTION_KEY=change-me-96-random-hex-characters
# Wrap the alternation in a single (?:...) group: TYPO3 anchors the pattern as
# /^<pattern>$/i, so a bare a|b|c would leave the middle branches unanchored and
# accept spoofed Host headers. Prefer pinning to your concrete production domain.
TYPO3_TRUSTED_HOSTS_PATTERN=(?:(.+\.)?vercel\.app|localhost(:[0-9]+)?|127\.0\.0\.1(:[0-9]+)?)
TYPO3_SERVERLESS_FILESYSTEM=1
TYPO3_CACHE_BACKEND=file

# Outgoing mail. The container ships no local MTA, so the TYPO3 'sendmail'
# default cannot deliver on Vercel. Configure an external SMTP relay for any
# site that sends mail (form submissions, notifications, password resets):
# TYPO3_MAIL_TRANSPORT=smtp
# TYPO3_MAIL_SMTP_SERVER=smtp.example.com:587
# TYPO3_MAIL_SMTP_ENCRYPT=tls
# TYPO3_MAIL_SMTP_USERNAME=<smtp-user>
# TYPO3_MAIL_SMTP_PASSWORD=<smtp-password>

# Standalone TYPO3 Install Tool access (reached via ?__typo3_install) is disabled
# by default. Authenticated system maintainers can still use the System backend
# modules. The password hash alone does not enable standalone access. Opt in
# only when needed, and disable the explicit switch again afterwards:
# TYPO3_INSTALL_TOOL_ENABLED=0
# TYPO3_INSTALL_TOOL_PASSWORD_HASH=

# Use 1 for one deploy after rotating TYPO3_SETUP_ADMIN_PASSWORD, then set it
# back to 0. Keeping it enabled hashes and writes the password on every cold
# container start.
TYPO3_ADMIN_PASSWORD_APPLY_ON_BOOT=0

# Set to 1 for one deploy after adding/removing TYPO3 extensions against an
# existing durable database. It runs `typo3 extension:setup` on container boot.
TYPO3_EXTENSION_SETUP_ON_BOOT=0

# Optional shared Redis cache. The official Redis Vercel Marketplace
# integration injects REDIS_URL automatically. TYPO3 needs a redis:// or
# rediss:// TCP/TLS endpoint; Upstash/Vercel REST variables are not enough for
# TYPO3's native Redis cache backend.
# TYPO3_CACHE_BACKEND=redis
# TYPO3_REDIS_REQUIRED=1
# TYPO3_REDIS_URL=rediss://default:<password>@<host>:6379/0
# TYPO3_REDIS_PREFIX=typo3-camino-vercel:
# TYPO3_REDIS_CONNECTION_TIMEOUT=1
# Persistent connections default to off: ephemeral, scale-to-zero containers
# reuse workers whose long-lived socket a cloud Redis may have already closed,
# causing "read error on connection" on the next command. Set to 1 only if your
# Redis and runtime keep connections reliably warm.
# TYPO3_REDIS_PERSISTENT_CONNECTION=0
#
# Alternative component-style Redis config when your provider does not expose
# one complete URL. TYPO3_REDIS_HOST may also include redis://, rediss://, or
# tls:// plus a port/path when a provider gives an endpoint in that shape:
# TYPO3_REDIS_HOST=<host-or-rediss-url>
# TYPO3_REDIS_PORT=6380
# TYPO3_REDIS_TLS=1
# TYPO3_REDIS_USERNAME=default
# TYPO3_REDIS_PASSWORD=<password>
# TYPO3_REDIS_DATABASE=0

# Optional Apache Solr search. TYPO3 14.3 currently matches EXT:solr
# 14.0.0-beta3 and Apache Solr 10.0.0. Use an external managed Solr service
# for production; do not run Solr as writable state inside this TYPO3 container.
# TYPO3_SOLR_ENABLED=1
# TYPO3_SOLR_SITE_BASE=https://your-project.vercel.app/
# TYPO3_SOLR_URL=https://user:password@<solr-host>:443/solr/core_en
# For the experimental internal Vercel demo service, omit TYPO3_SOLR_URL.
# Vercel injects TYPO3_SOLR_SERVICE_URL through the service binding.
# TYPO3_SOLR_SITE_IDENTIFIER=camino
# TYPO3_SOLR_APPLY_SITE_SET=1
# TYPO3_SOLR_SITE_SET=webconsulting/typo3-vercel-solr-demo
# TYPO3_SOLR_INCLUDE_STYLESHEETS=1
# TYPO3_SOLR_STYLESHEET_SITE_SET=webconsulting/typo3-vercel-solr-demo-stylesheets
# TYPO3_SOLR_SEARCH_SLUG=/search
# For the internal Vercel demo service, runtime indexing is skipped by default
# and the Solr service self-seeds demo documents. Set to 1 only for managed Solr
# or when you intentionally want to test bounded runtime indexing.
# TYPO3_SOLR_INDEX_ON_SETUP=0
# CRON_SECRET=<long-random-token-for-protected-setup-endpoints>
# Create the demo /search page through /api/cron/typo3-solr-demo.php after
# deploy. Solr page setup/indexing is not supported during Vercel boot.
# TYPO3_EXTENSION_SETUP_ON_BOOT=1 # one deploy only for older durable DBs

# Image processing and temporary files. The container includes ImageMagick,
# AVIF/WebP support, and Ghostscript; temporary files are kept under /tmp.
TYPO3_GFX_PROCESSOR=ImageMagick
TYPO3_GFX_PROCESSOR_PATH=/usr/bin/

# Optional CDN caching for anonymous public frontend HTML on Vercel.
# Keep disabled while testing editors, forms, personalization, or uncached plugins.
# TYPO3_VERCEL_EDGE_CACHE_TTL=600
# TYPO3_VERCEL_EDGE_CACHE_STALE_WHILE_REVALIDATE=3600
# Pro only: deploy with `vercel --prod -A vercel.pro.json` to run the protected
# three-minute TYPO3 frontend/backend/Solr warmup and 15-minute Scheduler cron.
# Keep vercel.json for Hobby, where Vercel permits cron only once per day.

# Leave DATABASE_URL unset for the free seeded SQLite demo.
# Add it before first deploy when you want durable content.
# DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require

# Optional: durable TYPO3 uploads through Vercel Blob.
# Create/connect a public Blob store with `vercel blob create-store ...`.
# New Vercel Blob connections use short-lived request OIDC by default. The FAL
# driver consumes that token automatically; BLOB_READ_WRITE_TOKEN remains a
# compatibility fallback for older stores and non-request CLI work.
# TYPO3_OBJECT_STORAGE_ENABLED=1
# TYPO3_OBJECT_STORAGE_DRIVER=vercel_blob
# TYPO3_OBJECT_STORAGE_VERIFY_ON_BOOT=1
# TYPO3_BLOB_STORE_ID=<store-id-if-BLOB_STORE_ID-is-not-injected>
# TYPO3_BLOB_ACCESS=public
# TYPO3_BLOB_PREFIX=typo3/
# TYPO3_BLOB_PROCESSING_FOLDER=_processed_
# Local seed-storage derivatives live on object storage by default
# ("2:/_processed_local_/", ADR-010). "local" reverts; "unmanaged" opts out.
# TYPO3_LOCAL_STORAGE_PROCESSING_FOLDER=2:/_processed_local_/
# Direct browser-to-Blob uploads default to 5 GiB and four-hour tokens. The
# standard TYPO3 uploader remains limited to 4 MB by Vercel's request limit.
# TYPO3_BLOB_DIRECT_UPLOAD_MAX_BYTES=5368709120
# TYPO3_BLOB_DIRECT_UPLOAD_TOKEN_TTL=14400

# Alternative: durable TYPO3 uploads through the included S3-compatible FAL
# driver. Cloudflare R2, AWS S3, MinIO, DigitalOcean Spaces, and similar
# S3-compatible services can work here.
# TYPO3_OBJECT_STORAGE_ENABLED=1
# TYPO3_OBJECT_STORAGE_DRIVER=vercel_s3
# TYPO3_OBJECT_STORAGE_VERIFY_ON_BOOT=1
# TYPO3_S3_BUCKET=your-bucket-name
# TYPO3_S3_REGION=auto
# TYPO3_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# TYPO3_S3_ACCESS_KEY_ID=<object-storage-access-key>
# TYPO3_S3_SECRET_ACCESS_KEY=<object-storage-secret-key>
# TYPO3_S3_PUBLIC_BASE_URL=https://files.example.com/
# TYPO3_S3_PREFIX=typo3/
# TYPO3_S3_PATH_STYLE_ENDPOINT=1
# TYPO3_S3_PROCESSING_FOLDER=_processed_
