{
    "name": "dirnbauer/typo3-camino-vercel",
    "description": "TYPO3 14.3 Camino container starter for Vercel Services",
    "license": "GPL-2.0-or-later",
    "type": "project",
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        },
        "platform": {
            "php": "8.5.0"
        },
        "sort-packages": true
    },
    "require": {
        "apache-solr-for-typo3/solr": "^14.0@beta",
        "friendsoftypo3/visual-editor": "^1.8",
        "lochmueller/staticfilecache": "^16.1",
        "typo3/cms-backend": "^14.3",
        "typo3/cms-belog": "^14.3",
        "typo3/cms-beuser": "^14.3",
        "typo3/cms-core": "^14.3",
        "typo3/cms-dashboard": "^14.3",
        "typo3/cms-extbase": "^14.3",
        "typo3/cms-extensionmanager": "^14.3",
        "typo3/cms-felogin": "^14.3",
        "typo3/cms-filelist": "^14.3",
        "typo3/cms-filemetadata": "^14.3",
        "typo3/cms-fluid": "^14.3",
        "typo3/cms-fluid-styled-content": "^14.3",
        "typo3/cms-form": "^14.3",
        "typo3/cms-frontend": "^14.3",
        "typo3/cms-impexp": "^14.3",
        "typo3/cms-info": "^14.3",
        "typo3/cms-install": "^14.3",
        "typo3/cms-linkvalidator": "^14.3",
        "typo3/cms-lowlevel": "^14.3",
        "typo3/cms-reactions": "^14.3",
        "typo3/cms-recycler": "^14.3",
        "typo3/cms-redirects": "^14.3",
        "typo3/cms-reports": "^14.3",
        "typo3/cms-rte-ckeditor": "^14.3",
        "typo3/cms-scheduler": "^14.3",
        "typo3/cms-seo": "^14.3",
        "typo3/cms-sys-note": "^14.3",
        "typo3/cms-tstemplate": "^14.3",
        "typo3/cms-viewpage": "^14.3",
        "typo3/cms-webhooks": "^14.3",
        "typo3/cms-workspaces": "^14.3",
        "typo3/theme-camino": "^14.3",
        "webconsulting/typo3-camino-demo": "^1.0",
        "webconsulting/typo3-object-storage-core": "^1.0",
        "webconsulting/typo3-vercel-blob-storage": "^1.0",
        "webconsulting/typo3-vercel-solr-demo": "^1.0",
        "webconsulting/typo3-vercel-storage": "^1.0"
    },
    "repositories": {
        "packages": {
            "options": {
                "versions": {
                    "webconsulting/typo3-camino-demo": "1.0.0",
                    "webconsulting/typo3-object-storage-core": "1.0.0",
                    "webconsulting/typo3-vercel-blob-storage": "1.0.0",
                    "webconsulting/typo3-vercel-solr-demo": "1.0.0",
                    "webconsulting/typo3-vercel-storage": "1.0.0"
                }
            },
            "type": "path",
            "url": "./packages/*"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.2"
    },
    "scripts": {
        "post-install-cmd": [
            "@restore-project-files"
        ],
        "post-update-cmd": [
            "@restore-project-files"
        ],
        "restore-project-files": "@php scripts/restore-project-files.php",
        "test": "@php vendor/bin/phpunit",
        "test:unit": "@php vendor/bin/phpunit --testsuite unit"
    }
}
