# Copy to .env.hetzner, replace every change-me value, and keep that file out
# of version control. Run Compose with: docker compose --env-file .env.hetzner
SITE_ADDRESS=www.example.com
TYPO3_SOLR_SITE_BASE=https://www.example.com/
TYPO3_TRUSTED_HOSTS_PATTERN=(?:www\.example\.com|example\.com)

TYPO3_PROJECT_NAME=TYPO3 Camino
TYPO3_SETUP_ADMIN_USERNAME=admin
TYPO3_SETUP_ADMIN_EMAIL=admin@example.com
TYPO3_SETUP_ADMIN_PASSWORD=change-me-with-a-long-random-password-1A!
TYPO3_ENCRYPTION_KEY=change-me-with-96-random-hex-characters
TYPO3_DB_DBNAME=typo3
TYPO3_DB_USERNAME=typo3
TYPO3_DB_PASSWORD=change-me-database-password
MARIADB_ROOT_PASSWORD=change-me-root-database-password
TYPO3_REDIS_PASSWORD=change-me-redis-password
CRON_SECRET=change-me-cron-secret

# Use both values only for the first start against an empty database. Change
# both back to 0 immediately after the app reports healthy.
TYPO3_AUTO_SETUP=0
TYPO3_BOOTSTRAP_EMPTY_DATABASE=0

# SMTP is required for forms, notifications, and password resets.
TYPO3_MAIL_TRANSPORT=smtp
TYPO3_MAIL_SMTP_SERVER=smtp.example.com:587
TYPO3_MAIL_SMTP_ENCRYPT=tls
TYPO3_MAIL_SMTP_USERNAME=
TYPO3_MAIL_SMTP_PASSWORD=

# Optional overrides:
# TYPO3_APP_IMAGE=registry.example.com/typo3-camino:release
# TYPO3_EXTENSION_SETUP_ON_BOOT=0
# TYPO3_SCHEDULER_LOOP_INTERVAL=60
# TYPO3_SOLR_SCHEDULER_INTERVAL=300
# HTTP_PORT=80
# HTTPS_PORT=443
