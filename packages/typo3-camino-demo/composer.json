{
    "name": "webconsulting/typo3-camino-demo",
    "description": "Reproducible multilingual Camino and Visual Editor demo content",
    "license": "GPL-2.0-or-later",
    "type": "typo3-cms-extension",
    "require": {
        "friendsoftypo3/visual-editor": "^1.8",
        "php": "^8.5",
        "symfony/console": "^7.4 || ^8.0",
        "typo3/cms-core": "^14.3",
        "typo3/cms-frontend": "^14.3",
        "typo3/cms-fluid": "^14.3",
        "typo3/theme-camino": "^14.3"
    },
    "autoload": {
        "psr-4": {
            "Webconsulting\\Typo3CaminoDemo\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "typo3_camino_demo"
        }
    }
}
