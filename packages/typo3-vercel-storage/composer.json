{
    "name": "webconsulting/typo3-vercel-storage",
    "description": "TYPO3 FAL storage driver helpers for Vercel container deployments",
    "license": "GPL-2.0-or-later",
    "type": "typo3-cms-extension",
    "require": {
        "aws/aws-sdk-php": "^3.369",
        "php": "^8.5",
        "symfony/mime": "^7.4 || ^8.0",
        "typo3/cms-core": "^14.3"
    },
    "autoload": {
        "psr-4": {
            "Webconsulting\\Typo3VercelStorage\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "typo3_vercel_storage"
        }
    }
}
