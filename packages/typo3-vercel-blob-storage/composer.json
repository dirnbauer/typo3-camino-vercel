{
    "name": "webconsulting/typo3-vercel-blob-storage",
    "description": "TYPO3 FAL driver and secure direct-upload integration for Vercel Blob storage",
    "type": "typo3-cms-extension",
    "license": "GPL-2.0-or-later",
    "require": {
        "guzzlehttp/guzzle": "^7.4",
        "php": "^8.5",
        "symfony/mime": "^7.4 || ^8.0",
        "typo3/cms-backend": "^14.3",
        "typo3/cms-core": "^14.3",
        "typo3/cms-filelist": "^14.3",
        "webconsulting/typo3-object-storage-core": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Webconsulting\\Typo3VercelBlobStorage\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "typo3_vercel_blob_storage"
        }
    }
}
