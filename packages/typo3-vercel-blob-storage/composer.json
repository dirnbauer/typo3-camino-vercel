{
    "name": "webconsulting/typo3-vercel-blob-storage",
    "description": "TYPO3 FAL driver for Vercel Blob storage",
    "type": "typo3-cms-extension",
    "license": "GPL-2.0-or-later",
    "require": {
        "guzzlehttp/guzzle": "^7.4",
        "php": "^8.4",
        "typo3/cms-core": "^14.3"
    },
    "autoload": {
        "psr-4": {
            "Webconsulting\\Typo3VercelBlobStorage\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "typo3_vercel_blob_storage"
        }
    }
}
